# ============================================
# PRODUCTION ENVIRONMENT - plannerate.cloud
# ============================================

# Application
APP_NAME="Plannerate"
APP_ENV=production
APP_KEY=base64:GERAR_COM_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://plannerate.cloud
APP_LOCALE=pt_BR
DOMAIN=plannerate.cloud

# Database PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=plannerate_production
DB_USERNAME=plannerate_prod_user
DB_PASSWORD=SUPER_SECRET_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=SUPER_SECRET_PASSWORD
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Cache & Queue
CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.plannerate.cloud
SESSION_SECURE_COOKIE=true
SESSION_LIFETIME=120

# Broadcasting (Reverb)
BROADCAST_CONNECTION=reverb
BROADCAST_DRIVER=reverb
REVERB_APP_ID=plannerate-production
REVERB_APP_KEY=SUPER_SECRET_KEY
REVERB_APP_SECRET=SUPER_SECRET_SECRET
REVERB_HOST=reverb.plannerate.cloud
REVERB_PORT=443
REVERB_SCHEME=https

# Mail (configure com provedor real: SES, Mailgun, SendGrid, etc)
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@plannerate.cloud
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 / DigitalOcean Spaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=plannerate-production
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
AWS_URL=

# DigitalOcean Spaces (alternativa ao S3)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=plannerate-production

# Logs
LOG_CHANNEL=stack
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# Sentry (monitoramento de erros - recomendado para produção)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# Outros
FILESYSTEM_DISK=s3

# Vite (para o frontend)
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Legacy Database (para importação de dados - remover após migração completa)
LEGACY_DB_CONNECTION=mysql
LEGACY_DB_HOST=142.93.177.44
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=plannerate_legacy
LEGACY_DB_USERNAME=plannerate_legacy
LEGACY_DB_PASSWORD=
