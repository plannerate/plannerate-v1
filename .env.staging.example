# ============================================
# STAGING ENVIRONMENT - plannerate.dev.br
# ============================================

# ============================================
# APPLICATION
# ============================================
APP_NAME="Plannerate Staging"
APP_ENV=staging
APP_KEY=base64:GERAR_COM_php_artisan_key:generate
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://plannerate.dev.br
APP_LOCALE=pt_BR
DOMAIN=plannerate.dev.br

# ============================================
# DATABASE - PostgreSQL
# ============================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=plannerate_staging
DB_USERNAME=plannerate_staging_user
DB_PASSWORD=SUA_SENHA_POSTGRES_AQUI

# Outras configurações PostgreSQL
DB_SCHEMA=public
DB_SSLMODE=prefer

PGADMIN_PASSWORD=SUA_SENHA_PGADMIN_AQUI

# ============================================
# REDIS
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=SUA_SENHA_REDIS_AQUI
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ============================================
# CACHE & QUEUE & SESSION
# ============================================
CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.plannerate.dev.br
SESSION_SECURE_COOKIE=true

# ============================================
# BROADCASTING - REVERB
# ============================================
BROADCAST_CONNECTION=reverb
BROADCAST_DRIVER=reverb
REVERB_APP_ID=plannerate-staging
REVERB_APP_KEY=SUA_REVERB_APP_KEY_AQUI
REVERB_APP_SECRET=SUA_REVERB_APP_SECRET_AQUI
REVERB_HOST=reverb.plannerate.dev.br
REVERB_PORT=443
REVERB_SCHEME=https

# ============================================
# REVERB INTERNAL (Conexão Laravel -> Reverb)
# ============================================
# IMPORTANTE: Quando Laravel e Reverb estão no mesmo container,
# use localhost para conexão interna (mais rápido e confiável)
# Se não definido, usa REVERB_HOST/REVERB_PORT/REVERB_SCHEME
REVERB_INTERNAL_HOST=localhost
REVERB_INTERNAL_PORT=8080
REVERB_INTERNAL_SCHEME=http

# ============================================
# VITE - Frontend Build Variables
# ============================================
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ============================================
# MAIL
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=seu_usuario_mailtrap
MAIL_PASSWORD=sua_senha_mailtrap
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=staging@plannerate.dev.br
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS S3 / DigitalOcean Spaces
# ============================================
AWS_ACCESS_KEY_ID=SUA_AWS_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=SUA_AWS_SECRET_KEY_AQUI
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=plannerate-staging
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
AWS_URL=

# DigitalOcean Spaces (alternativa ao S3)
DO_ACCESS_KEY_ID=SUA_DO_ACCESS_KEY_AQUI
DO_SECRET_ACCESS_KEY=SUA_DO_SECRET_KEY_AQUI
DO_DEFAULT_REGION=sfo3
DO_BUCKET=plannerate-staging
DO_ENDPOINT=https://sfo3.digitaloceanspaces.com

PLANNERATE_AUTO_GENERATE_ENABLED=true

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# ============================================
# FILESYSTEM
# ============================================
FILESYSTEM_DISK=public

# ============================================
# LEGACY DATABASE (Importação de dados)
# ============================================
LEGACY_DB_HOST=SEU_LEGACY_DB_HOST_AQUI
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=SEU_LEGACY_DB_DATABASE_AQUI
LEGACY_DB_USERNAME=SEU_LEGACY_DB_USERNAME_AQUI
LEGACY_DB_PASSWORD=SUA_LEGACY_DB_PASSWORD_AQUI

# ============================================
# GITHUB
# ============================================
GITHUB_REPO=callcocam/plannerate
