# Copiar para /etc/plannerate/spaces-backup-credentials.env na VPS do banco
# (72.62.139.43) e preencher com valores reais. NUNCA versionar o arquivo preenchido.
#
# O script roda como usuário OS "postgres" — não como root — então tanto o
# diretório quanto o arquivo precisam ser legíveis por ele (/root é 700 e
# bloqueia até root outros usuários, por isso não fica lá):
#   mkdir -p /etc/plannerate
#   chown postgres:postgres /etc/plannerate
#   chmod 750 /etc/plannerate
#   chown postgres:postgres /etc/plannerate/spaces-backup-credentials.env
#   chmod 600 /etc/plannerate/spaces-backup-credentials.env

SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_REGION=sfo3
SPACES_BUCKET=planify
SPACES_ACCESS_KEY_ID=replace-with-real-key
SPACES_SECRET_ACCESS_KEY=replace-with-real-secret
