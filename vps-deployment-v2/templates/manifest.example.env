PROJECT_NAME=plannerate

# Landlord domain (root domain). Tenants use subdomains via app routing.
DOMAIN_LANDLORD=app.example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
ACME_EMAIL=ops@example.com

# Deployment user
DEPLOY_USER=deploy
VPS_DEPLOY_USER=deploy
VPS_HOST=203.0.113.10
SSH_PORT=22

# Registry
GHCR_REPO=callcocam/plannerate-v1

# GitHub bootstrap
GITHUB_OWNER=callcocam
GITHUB_REPO_NAME=plannerate-v1

# Inject GitHub Actions public key used for deployment
GITHUB_DEPLOY_PUBLIC_KEY='ssh-ed25519 AAAA...replace-me'

# Traefik dashboard auth generated with:
# htpasswd -nb admin 'strong-password' | sed -e s/\$/\$\$/g
TRAEFIK_DASHBOARD_BASICAUTH=admin:$$apr1$$replace$$$$replace

# Application DB (single active environment)
# DB_MODE: local (banco na mesma VPS) | externo (VPS separada para o banco)
DB_MODE=local
DB_ENGINE=pgsql
DB_CONNECTION_DEFAULT=landlord
# local (containers): host.docker.internal (recomendado) ou 172.17.0.1 (fallback)
# DB_LOCAL_HOST_FALLBACK permite ajustar o fallback local aceito na validação.
DB_LOCAL_HOST_FALLBACK=172.17.0.1
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=plannerate_staging
DB_USER=plannerate_stg
DB_PASSWORD=replace-db-password
DB_TENANT_DATABASE=plannerate_staging
DB_LANDLORD_HOST=host.docker.internal
DB_LANDLORD_PORT=5432
DB_LANDLORD_DATABASE=plannerate_staging
DB_LANDLORD_USERNAME=plannerate_stg
DB_LANDLORD_PASSWORD=replace-db-password

# DB host installation parameters
DB_ALLOWED_CIDR=10.10.0.0/24
DB_ALLOWED_HOST=%

# SSH key dedicada ao host do banco (gerada automaticamente pelo provision-external-db.sh)
# Preenchido automaticamente pelo wizard — não altere manualmente
# DB_SSH_KEY_PATH=~/.ssh/id_ed25519_plannerate_db

# Senha root da VPS do banco para 1ª conexão (bootstrap inicial)
# Removida/esvaziada após o bootstrap — não deixar em produção
# DB_BOOTSTRAP_ROOT_PASS=

# Optional predefined redis password
# REDIS_PASSWORD=replace

# Backup target: DigitalOcean Spaces (S3 compatible)
BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_REGION=us-east-1
BACKUP_S3_BUCKET=plannerate-backups
BACKUP_S3_PREFIX=plannerate-v2
BACKUP_S3_ACCESS_KEY_ID=replace-do-spaces-key
BACKUP_S3_SECRET_ACCESS_KEY=replace-do-spaces-secret

# Tabelas para backup seletivo (comma-separated). Vazio = banco inteiro.
# Sistema multitenant: inclua as tabelas do landlord que precisam de backup granular.
# MySQL:      BACKUP_TABLES=tenants,users,plans,subscriptions
# PostgreSQL: BACKUP_TABLES=public.tenants,public.users,public.plans
# O wizard de setup pergunta por este valor automaticamente.
BACKUP_TABLES=

# Backup cron schedule (default: 02:10 daily)
BACKUP_CRON_MINUTE=10
BACKUP_CRON_HOUR=2
BACKUP_CRON_DAY_OF_MONTH=*
BACKUP_CRON_MONTH=*
BACKUP_CRON_DAY_OF_WEEK=*
BACKUP_LOG_DIR=/var/log/plannerate

# Monitoring stack
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_DOMAIN=prometheus.example.com
ALERTMANAGER_DOMAIN=alerts.example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-grafana-admin-password
PROMETHEUS_RETENTION=15d

# Alertas por e-mail (Alertmanager email_configs). Reutilize o SMTP da app Laravel.
# SMTP_REQUIRE_TLS deve ser true|false (STARTTLS). Para porta 465 (SMTPS) use false + smarthost 465.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USER=alerts@example.com
SMTP_PASS=replace-smtp-password
SMTP_REQUIRE_TLS=true
ALERT_EMAIL_TO=ops@example.com
ALERT_EMAIL_CRITICAL_TO=ops@example.com

# Token do endpoint /metrics da app (deve ser IGUAL ao METRICS_TOKEN do .env da app).
# Usado pelo Prometheus para raspar as métricas de fila/Horizon via Traefik.
METRICS_TOKEN=replace-metrics-token

# Optional pgAdmin (dev/staging only)
ENABLE_PGADMIN=false
PGADMIN_DOMAIN=pgadmin.example.com
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-pgadmin-password

# Dedicated backup failure notification webhook
BACKUP_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/replace-backup-fail

# Validation
MIN_DISK_GB=20

# VPS health cron (default: every 15 minutes)
HEALTH_CRON_MINUTE=*/15
HEALTH_CRON_HOUR=*
HEALTH_CRON_DAY_OF_MONTH=*
HEALTH_CRON_MONTH=*
HEALTH_CRON_DAY_OF_WEEK=*
HEALTH_LOG_DIR=/var/log/plannerate
