APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.example.com
DOMAIN=app.example.com
GHCR_REPO=callcocam/plannerate-v1
IMAGE_TAG=latest

DB_CONNECTION=mysql
DB_HOST=10.10.0.10
DB_PORT=3306
DB_DATABASE=plannerate_production
DB_USERNAME=plannerate_prod
DB_PASSWORD=replace-prod-db-password

REDIS_HOST=redis
REDIS_PASSWORD=replace-redis-password
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
BROADCAST_CONNECTION=reverb

REVERB_HOST=reverb.app.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_DOMAIN=reverb.app.example.com

VITE_REVERB_HOST=${REVERB_HOST}
VITE_REVERB_PORT=${REVERB_PORT}
VITE_REVERB_SCHEME=${REVERB_SCHEME}
