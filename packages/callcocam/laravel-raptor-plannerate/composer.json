{
    "name": "callcocam/laravel-raptor-plannerate",
    "description": "Private Plannerate package for planogram editor frontend and backend domain.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0|^13.0",
        "inertiajs/inertia-laravel": "^3.0",
        "callcocam/laravel-raptor-flow": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Callcocam\\LaravelRaptorPlannerate\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Callcocam\\LaravelRaptorPlannerate\\LaravelRaptorPlannerateServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
