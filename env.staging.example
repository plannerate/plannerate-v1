# ============================================
# STAGING ENVIRONMENT - plannerate.dev.br
# ============================================

# ============================================
# APPLICATION
# ============================================
APP_NAME="Plannerate Staging"
APP_ENV=staging
APP_KEY=base64:GERAR_COM_php_artisan_key:generate
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://plannerate.dev.br
APP_LOCALE=pt_BR
DOMAIN=plannerate.dev.br

# ============================================
# DATABASE - PostgreSQL (Servidor Externo)
# ============================================
# PostgreSQL roda em servidor externo (192.168.2.106)
# com replicação (1 primário + 2 réplicas)
DB_CONNECTION=pgsql
DB_HOST=192.168.2.106
DB_PORT=5432
DB_DATABASE=plannerate_staging
DB_USERNAME=replicator
DB_PASSWORD=replicator_password

# ============================================
# REDIS
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=c8f4e9a2b7d3f1e6c5a9b2d8
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ============================================
# CACHE & QUEUE & SESSION
# ============================================
CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.plannerate.dev.br
SESSION_SECURE_COOKIE=true

# ============================================
# BROADCASTING - REVERB
# ============================================
# Configuração do servidor Reverb (interno - roda no container)
BROADCAST_CONNECTION=reverb
BROADCAST_DRIVER=reverb
REVERB_SERVER=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=

# Configuração da aplicação Reverb (credenciais)
REVERB_APP_ID=plannerate-staging
REVERB_APP_KEY=zvk8x2m9p4n7q5w6
REVERB_APP_SECRET=f2a9c5e8b1d7f3a6c9e2b4d8f1a5c7e9b3d6f2a8c4e1b9d5f7a3c6e8b2d4f1a9

# Configuração do cliente Reverb (acessível externamente via Traefik)
# IMPORTANTE: Estas são as variáveis que o frontend (Vite) usa para conectar
REVERB_HOST=reverb.plannerate.dev.br
REVERB_PORT=443
REVERB_SCHEME=https

# Configurações opcionais do Reverb
REVERB_MAX_REQUEST_SIZE=10000
REVERB_SCALING_ENABLED=false
REVERB_APP_PING_INTERVAL=60
REVERB_APP_ACTIVITY_TIMEOUT=30
REVERB_APP_MAX_CONNECTIONS=
REVERB_APP_MAX_MESSAGE_SIZE=10000

# ============================================
# VITE - Frontend Build Variables
# ============================================
# IMPORTANTE: Estas variáveis são injetadas no build do Vite
# Elas devem corresponder às variáveis REVERB_* acima
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ============================================
# MAIL
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=seu_usuario_mailtrap
MAIL_PASSWORD=sua_senha_mailtrap
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=staging@plannerate.dev.br
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# FILESYSTEM
# ============================================
FILESYSTEM_DISK=local

# ============================================
# AWS S3 / DigitalOcean Spaces
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=plannerate-staging
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
AWS_URL=

# DigitalOcean Spaces (alternativa ao S3)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=plannerate-staging

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# ============================================
# LEGACY DATABASE (Importação de dados)
# ============================================
LEGACY_DB_CONNECTION=mysql
LEGACY_DB_HOST=142.93.177.44
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=plannerate_legacy
LEGACY_DB_USERNAME=plannerate_legacy
LEGACY_DB_PASSWORD=
