APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=landlord
DB_USERNAME=sail
DB_PASSWORD=password
#
# Dedicated connections for multitenancy
DB_TENANT_CONNECTION=pgsql
# DB_TENANT_DATABASE=tenant_template
DB_LANDLORD_CONNECTION=pgsql
DB_LANDLORD_HOST=postgres
DB_LANDLORD_PORT=5432
DB_LANDLORD_DATABASE=landlord
DB_LANDLORD_USERNAME=sail
DB_LANDLORD_PASSWORD=password

POSTGRES_DB=landlord
POSTGRES_USER=sail
POSTGRES_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=landlord

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=plannerate
REVERB_APP_KEY=plannerate-key
REVERB_APP_SECRET=plannerate-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=landlord
DB_QUEUE_BATCHING_CONNECTION=landlord
DB_QUEUE_FAILED_CONNECTION=landlord

CACHE_STORE=database
DB_CACHE_CONNECTION=landlord
DB_CACHE_LOCK_CONNECTION=landlord
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=
